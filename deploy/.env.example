# sluice deployment configuration.
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# REQUIRED: API key used for /v1/usage polling (same key your clients send).
SLUICE_USAGE_KEY=sk-...

# REQUIRED: token gating admin routes (/, /status.json, /metrics, /history.json).
# Generate one with: openssl rand -hex 32
SLUICE_ADMIN_TOKEN=

# --- Optional tunables (defaults shown) ---

# Upstream provider base URL. Defaults to umans Code.
#SLUICE_UPSTREAM=https://api.code.umans.ai

# Provider type (umans, anthropic, openai, generic). Must match the upstream —
# e.g. set both to anthropic for https://api.anthropic.com (no SLUICE_USAGE_KEY
# needed for non-umans providers). See README "Other providers".
#SLUICE_PROVIDER=umans

# Target max concurrency. Default 4 (full umans Code Max limit, matching k8s).
# Set to 3 for a one-slot safety buffer. See README "Tuning".
#SLUICE_TARGET=4

# Seconds between /v1/usage polls
#SLUICE_POLL_INTERVAL=5

# Seconds a freed permit rests before reuse
#SLUICE_RELEASE_COOLDOWN=2

# Max seconds to wait for a permit before 503
#SLUICE_QUEUE_TIMEOUT=30

# Host port to expose (container always listens on 8800)
#SLUICE_PORT=8800

# Trusted proxy CIDR allowlist for x-sluice-client-label (default: loopback-only).
# Set to your reverse proxy's CIDR if running behind Traefik/nginx/Caddy.
#SLUICE_TRUSTED_PROXIES=172.16.0.0/12
