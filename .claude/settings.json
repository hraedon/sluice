{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "agent-notes orient --path /projects/sluice 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "agent-notes outbox reconcile >/dev/null || true"
          }
        ]
      }
    ]
  }
}
